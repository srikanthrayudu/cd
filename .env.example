# .env.example — copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# .env is ignored by git (.gitignore). Never commit real secrets.

# ── OpenAI backend (optional) ─────────────────────────────────────────────────
# Required only when running:  python3 main.py --backend openai
OPENAI_API_KEY=sk-your-key-here

# ── Optional feature flags ────────────────────────────────────────────────────
# Set to "1" to run the Alive2 semantic validator after llvm-as + opt.
# Requires alive-tv on PATH.
ALIVE2_VALIDATE=0

# Set to "1" to run opt -passes=mem2reg (SSA repair) during validation.
# Useful if generated IR contains alloca/store patterns that need promotion.
SSA_FIX=0
